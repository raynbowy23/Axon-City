# Umami analytics — leave unset to disable tracking entirely (e.g. local dev).
# VITE_UMAMI_SRC is the tracker script URL of your Umami instance:
#   Umami Cloud:  https://cloud.umami.is/script.js
#   Self-hosted:  https://analytics.example.com/script.js
# VITE_UMAMI_WEBSITE_ID comes from the website settings in the Umami dashboard.
VITE_UMAMI_SRC=
VITE_UMAMI_WEBSITE_ID=
# Optional: comma-separated hostnames the tracker may run on
# (prevents forks/preview deploys from sending events to your dashboard)
VITE_UMAMI_DOMAINS=
